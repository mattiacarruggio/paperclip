DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Trust proxy headers (X-Forwarded-Host, X-Forwarded-Proto, X-Forwarded-For).
# Default: unset / false. Leave unset unless the server actually sits behind
# a reverse proxy you control. When unset, X-Forwarded-Host is ignored so a
# client cannot spoof the host header to bypass the private-hostname guard
# or extend the board-mutation trusted-origin set.
# Accepted values:
#   true               - trust all proxies (only safe when not exposed directly)
#   <integer>          - number of proxy hops to trust (e.g. 1)
#   loopback           - trust 127.0.0.1/8, ::1/128
#   uniquelocal        - trust private subnets
#   "10.0.0.0/8,..."   - comma-separated subnet list
# PAPERCLIP_TRUST_PROXY=loopback
